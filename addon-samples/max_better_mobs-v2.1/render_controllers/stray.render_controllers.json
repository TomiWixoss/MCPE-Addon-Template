{
  "format_version": "1.8.0",
  "render_controllers": {
    "controller.render.stray": {
      "rebuild_animation_matrices": true,
      "geometry": "Array.Xgeos[variable.Xvar]",
      "materials": [ { "*": "Material.default" } ],
      "textures": [ "Array.Xskins[variable.Xvar]" ],
      "arrays": {
        "textures": {
          "Array.Xskins": [
            "Texture.default",
            "Texture.default2",
            "Texture.default3"
          ]
        },
        "geometries": {
          "Array.Xgeos": [
            "Geometry.default",
            "Geometry.default2",
            "Geometry.default3"
          ]
        }
      }      
    }
  }
}